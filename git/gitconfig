[core]
  excludesfile = ~/.gitignore_global
  autocrlf = input
  editor = vim
  timezone = Asia/Shanghai
[include]
  path = ~/.gitconfig.local
[color]
  ui = true
[push]
  default = simple
  autoSetupRemote = true
[checkout]
  defaultRemote = origin
[diff]
  tool = vimdiff
[difftool]
  prompt = false
