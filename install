#!/usr/bin/env bash
# Top-level entrypoint. Delegates to scripts/install.sh (a small bash
# replacement for dotbot). No external dependencies beyond bash, coreutils
# and the system tools each post-link hook needs.
set -e
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$BASEDIR/scripts/install.sh" "$@"
